#!/usr/bin/env bash
# engine/run — the reconcile core. Sources the config repo's `botufile` (a bash
# DSL) once, under a VERB, and each declaration acts immediately for that verb.
#
#   run apply  ≈ sync     run verify ≈ doctor     run fix ≈ doctor --fix
#
# No JSON, no jq, no manifest parser, no providers/ directory: the config IS a
# short bash program of verb-aware primitives (link/copy/glob/brewfile/
# osx_default/hook). Trusts BOTU_CONFIG (the dispatcher resolved + exported it).
set -euo pipefail

VERB="${1:?run: need a verb}"
shift
case "$VERB" in
  apply | verify | fix | uninstall) ;;
  *)
    printf 'run: verb must be apply|verify|fix|uninstall (got %s)\n' "$VERB" >&2
    exit 2
    ;;
esac

ENGINE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO="${BOTU_CONFIG:?run: BOTU_CONFIG unset — run: botu init}"
[[ -f "$REPO/botufile" ]] || {
  printf 'run: no botufile under %s\n' "$REPO" >&2
  exit 1
}

DRY_RUN=0
LINK_MODE="interactive"
ONLY_TAGS=""
for _a in "$@"; do
  case "$_a" in
    --dry-run) DRY_RUN=1 ;;
    -f | --force) LINK_MODE="overwrite" ;;
    -s | --skip) LINK_MODE="skip" ;;
    --only=*) ONLY_TAGS="$(printf '%s' "${_a#--only=}" | tr ',' ' ')" ;;
  esac
done
export DRY_RUN LINK_MODE

# Concurrency lock — two mutating reconciles racing would corrupt state. Skipped
# for verify (read-only) and dry-run (mutates nothing). Stale lock (dead pid) is
# reclaimed.
if [[ "$VERB" != "verify" && "$DRY_RUN" != "1" ]]; then
  _LOCK="${XDG_STATE_HOME:-$HOME/.local/state}/botu/run.lock"
  mkdir -p "$(dirname "$_LOCK")"
  if [[ -f "$_LOCK" ]]; then
    _pid="$(cat "$_LOCK" 2> /dev/null || true)"
    if [[ "$_pid" =~ ^[0-9]+$ ]] && kill -0 "$_pid" 2> /dev/null; then
      printf 'botu: another run in progress (pid %s)\n' "$_pid" >&2
      exit 1
    fi
  fi
  printf '%s\n' "$$" > "$_LOCK"
  # shellcheck disable=SC2064  # expand $_LOCK now, at trap-set time
  trap "rm -f '$_LOCK'" EXIT
fi

# shellcheck source=engine/lib.sh
source "$ENGINE_DIR/lib.sh" # palette, os_kind, _symlink

_WARN=0
_FAIL=0
_warn() {
  _p_warn "$@"
  _WARN=$((_WARN + 1))
}
_fail() {
  _p_fail "$@"
  _FAIL=$((_FAIL + 1))
}

_disp() { printf '%s' "${1/#"$HOME"/\~}"; }
_abs() { printf '%s' "${1/#\~/$HOME}"; }

# _match TAG: honor --only. Empty filter ⇒ everything runs.
_match() {
  [[ -z "$ONLY_TAGS" ]] && return 0
  local o
  # shellcheck disable=SC2086  # word-split the space-separated filter on purpose
  for o in $ONLY_TAGS; do [[ "$1" == "$o" ]] && return 0; done
  return 1
}

# ── The config DSL ────────────────────────────────────────────────────────────
# Current section = the tag used for --only filtering + the printed header.
_SECTION="symlinks"
section() {
  _SECTION="$1"
  _match "$1" && _hdr "$1"
  return 0
}

# link [--mode M] SRC DST   — symlink SRC (repo-relative) to DST (~ allowed)
link() {
  local mode=""
  [[ "${1:-}" == "--mode" ]] && {
    mode="$2"
    shift 2
  }
  _match "$_SECTION" || return 0
  local src="$1" dst t
  dst="$(_abs "$2")"
  _DECLARED+=("$dst") # record what botu owns (for orphan reaping + uninstall)
  case "$VERB" in
    apply | fix)
      [[ "$VERB" == "fix" ]] && LINK_MODE="overwrite"
      _symlink "$REPO/$src" "$dst"
      [[ -n "$mode" && "$DRY_RUN" != "1" ]] && chmod "$mode" "$dst" 2> /dev/null || true
      ;;
    verify)
      local perms
      t="$(readlink "$dst" 2> /dev/null || true)"
      if [[ "$t" == "$REPO/$src" ]]; then
        if [[ -n "$mode" ]]; then
          perms="$(stat -Lf '%Lp' "$dst" 2> /dev/null || true)"
          if [[ "$perms" == "$mode" ]]; then _ok "$(_disp "$dst") (mode $mode)"; else _warn "$(_disp "$dst") mode $perms, expected $mode"; fi
        else
          _ok "$(_disp "$dst")"
        fi
      elif [[ -z "$t" ]]; then
        _fail "$(_disp "$dst") not linked (→ $src)"
      else
        _fail "$(_disp "$dst") → $t, expected $REPO/$src"
      fi
      ;;
    uninstall)
      t="$(readlink "$dst" 2> /dev/null || true)"
      [[ "$t" == "$REPO/$src" ]] || return 0 # only remove OUR link
      if [[ "$DRY_RUN" == "1" ]]; then _note "would remove $(_disp "$dst")"; else
        rm -f "$dst" && _ok "$(_disp "$dst") removed"
      fi
      ;;
  esac
}

# copy [--mode M] SRC DST   — install a real copy (e.g. the dot launcher itself)
copy() {
  local mode="0755"
  [[ "${1:-}" == "--mode" ]] && {
    mode="$2"
    shift 2
  }
  _match "$_SECTION" || return 0
  local src="$1" dst
  dst="$(_abs "$2")"
  _DECLARED+=("$dst")
  case "$VERB" in
    apply | fix)
      if [[ "$DRY_RUN" == "1" ]]; then
        printf '\033[0;36m  ~ %s would be copied\033[0m\n' "$(_disp "$dst")"
      else
        mkdir -p "$(dirname "$dst")"
        install -m "$mode" "$REPO/$src" "$dst"
        _ok "$(_disp "$dst") copied"
      fi
      ;;
    verify)
      if cmp -s "$REPO/$src" "$dst" 2> /dev/null; then _ok "$(_disp "$dst") (copy current)"; else _warn "$(_disp "$dst") copy missing/stale"; fi
      ;;
    uninstall)
      cmp -s "$REPO/$src" "$dst" 2> /dev/null || return 0 # only remove OUR copy
      if [[ "$DRY_RUN" == "1" ]]; then _note "would remove $(_disp "$dst")"; else
        rm -f "$dst" && _ok "$(_disp "$dst") removed"
      fi
      ;;
  esac
}

# glob SRCPAT DSTDIR        — link each match of SRCPAT into DSTDIR (keep name)
glob() {
  _match "$_SECTION" || return 0
  local dir f
  dir="$(_abs "$2")"
  # shellcheck disable=SC2231  # deliberate glob over the repo-relative pattern
  for f in "$REPO"/$1; do
    [[ -e "$f" ]] || continue
    link "${f#"$REPO"/}" "${dir%/}/$(basename "$f")"
  done
}

# brewfile FILE / mise_install  — packages via the stock tools
brewfile() {
  _SECTION="brew"
  _match brew || return 0
  _hdr "Homebrew ($1)"
  command -v brew > /dev/null 2>&1 || {
    _fail "brew not installed"
    return 0
  }
  case "$VERB" in
    apply | fix)
      if [[ "$DRY_RUN" == "1" ]]; then _note "would run: brew bundle --file=$REPO/$1"; else brew bundle --file="$REPO/$1" && _ok "brew bundle satisfied"; fi
      ;;
    verify)
      if brew bundle check --file="$REPO/$1" > /dev/null 2>&1; then _ok "brew bundle satisfied"; else _warn "brew bundle missing deps — run: botu apply --only=brew"; fi
      ;;
  esac
}

# mise_install              — install the toolchains in mise.toml
mise_install() {
  _SECTION="mise"
  _match mise || return 0
  command -v mise > /dev/null 2>&1 || return 0
  _hdr "mise"
  case "$VERB" in
    apply | fix) if [[ "$DRY_RUN" == "1" ]]; then _note "would run: mise install"; else mise install && _ok "mise tools installed"; fi ;;
    verify) _ok "mise present" ;;
  esac
}

# osx_default DOMAIN KEY TYPE VALUE  — a macOS default, OS-gated
osx_default() {
  _SECTION="macos"
  _match macos || return 0
  [[ "$(os_kind)" == "darwin" ]] || return 0
  local d="$1" k="$2" t="$3" v="$4" cur
  case "$VERB" in
    apply | fix)
      if [[ "$DRY_RUN" == "1" ]]; then
        _note "would set $d $k -$t $v"
      elif defaults write "$d" "$k" "-$t" "$v"; then
        _ok "$d $k = $v"
        _OSX_APPLIED=1 # engine restarts the UI at end of apply (see finalize)
      fi
      ;;
    verify)
      cur="$(defaults read "$d" "$k" 2> /dev/null || true)"
      case "$v" in true) v=1 ;; false) v=0 ;; esac
      if [[ "$cur" == "$v" ]]; then _ok "$d $k = $v"; else _warn "$d $k = ${cur:-<unset>}, expected $v"; fi
      ;;
  esac
}

# hook NAME [KEY=VAL ...]   — the imperative escape hatch (op-agent, claude, …).
# Sources hooks/NAME.sh and calls _NAME_<verb>; KEY=VAL pairs arrive as $BOTU_KEY.
hook() {
  local name="$1"
  shift
  _match "$name" || return 0
  local f="$REPO/hooks/$name.sh" kv
  [[ -f "$f" ]] || {
    _warn "hook $name: missing $f"
    return 0
  }
  for kv in "$@"; do export "BOTU_${kv%%=*}=${kv#*=}"; done
  # shellcheck source=/dev/null
  source "$f"
  local fn="_${name//-/_}_${VERB}"
  declare -f "$fn" > /dev/null 2>&1 && "$fn"
  for kv in "$@"; do unset "BOTU_${kv%%=*}"; done
  return 0
}

# on apply|verify CMD...    — run CMD inline for a verb. The botufile is bash, so
# small imperative steps need no hook file: `on apply lefthook install`. `apply`
# fires on apply AND fix (fix = repair = re-apply); `verify` fires on verify and
# folds CMD's exit code into the pass/fail tally. Honors --only (via section) and
# --dry-run. Use a hook file only for substantial logic, or when an external
# program execs the script by path (e.g. op-agent, called by an MCP headersHelper).
on() {
  local want="$1"
  shift
  case "$VERB" in
    apply | fix) [[ "$want" == "apply" ]] || return 0 ;;
    verify) [[ "$want" == "verify" ]] || return 0 ;;
    *) return 0 ;; # uninstall etc. — `on` is apply/verify only
  esac
  _match "$_SECTION" || return 0
  if [[ "$want" == "apply" && "${DRY_RUN:-0}" == "1" ]]; then
    _note "would run: $*"
    return 0
  fi
  local rc=0
  "$@" || rc=$?
  # A failed step counts toward the tally on both verbs (apply exits nonzero too).
  [[ "$rc" -ne 0 ]] && _fail "$* (exit $rc)"
  return 0
}

# Built-in verify-only policy: tracked .mcp.json/.env carry op:// refs, never
# ${VAR} placeholders (Claude Code #18692) or resolved-token literals (b8067ab).
_builtin_hygiene() {
  command -v git > /dev/null 2>&1 || return 0
  git -C "$REPO" rev-parse --git-dir > /dev/null 2>&1 || return 0
  _match mcp || return 0
  _hdr "MCP secret hygiene"
  local tokre='(gh[opsu]_|github_pat_|sbp_|glpat-|xox[baprs]-|AKIA[0-9A-Z]{16}|sk-[A-Za-z0-9]{16})'
  local clean=1 mf
  while IFS= read -r mf; do
    [[ -n "$mf" ]] || continue
    case "$mf" in
      *.mcp.json) grep -Eq '\$\{[A-Za-z_]' "$REPO/$mf" 2> /dev/null && {
        _warn "$mf has a \${VAR} placeholder (#18692)"
        clean=0
      } ;;
    esac
    grep -Eq "$tokre" "$REPO/$mf" 2> /dev/null && {
      _fail "$mf contains a resolved-token literal — commit op:// refs, never values"
      clean=0
    }
  done < <(cd "$REPO" && git ls-files '*.mcp.json' '*.env' '.env' 2> /dev/null || true)
  [[ "$clean" -eq 1 ]] && _ok "tracked .mcp.json/.env carry references only"
  # Always succeed: a dirty result is reported via _warn/_fail (which drive the
  # exit code). Returning the falsy `[[ clean ]]` above would, under `set -e`,
  # abort `… && _builtin_hygiene` before the verify summary.
  return 0
}

# ── Run ───────────────────────────────────────────────────────────────────────
[[ "$DRY_RUN" == "1" ]] && printf '\033[0;36m==> ~ dry run — no changes\033[0m\n'
printf '\033[1m==> botu %s\033[0m\n' "$VERB"

_OSX_APPLIED=0
_DECLARED=() # every dest link/copy/glob declares — populated while sourcing
_MANIFEST="${XDG_STATE_HOME:-$HOME/.local/state}/botu/manifest"

# shellcheck source=/dev/null
source "$REPO/botufile" # executes the DSL under $VERB
[[ "$VERB" == "verify" ]] && _builtin_hygiene

# Orphan reaping: a symlink botu made (recorded in the manifest last run) whose
# `link` line was since deleted from the botufile dangles forever — apply adds,
# nothing removed. Compare the prior manifest against what's declared NOW: an
# entry no longer declared but still pointing into $REPO is an orphan. verify
# warns; apply/fix reap. This is the missing half of the symlink contract.
_is_declared() {
  local d
  for d in ${_DECLARED+"${_DECLARED[@]}"}; do [[ "$d" == "$1" ]] && return 0; done
  return 1
}
_reap_orphans() {
  [[ -f "$_MANIFEST" ]] || return 0
  local d t shown=0
  while IFS= read -r d; do
    [[ -n "$d" ]] || continue
    _is_declared "$d" && continue
    t="$(readlink "$d" 2> /dev/null || true)"
    [[ "$t" == "$REPO/"* ]] || continue # only links into our repo
    [[ "$shown" -eq 0 ]] && {
      _hdr "Orphans"
      shown=1
    }
    if [[ "$VERB" == "verify" ]]; then
      _warn "$(_disp "$d") → $t (no longer declared — botu fix to reap)"
    elif [[ "$DRY_RUN" == "1" ]]; then
      _note "would reap $(_disp "$d")"
    else
      rm -f "$d" && _ok "reaped orphan $(_disp "$d")"
    fi
  done < "$_MANIFEST"
}
_reap_orphans

# Persist what botu owns now (mutating verbs, real runs only). uninstall removes
# everything, so it clears the manifest.
if [[ "$DRY_RUN" != "1" ]]; then
  case "$VERB" in
    apply | fix)
      mkdir -p "$(dirname "$_MANIFEST")"
      : > "$_MANIFEST"
      [[ "${#_DECLARED[@]}" -gt 0 ]] && printf '%s\n' "${_DECLARED[@]}" > "$_MANIFEST"
      ;;
    uninstall) rm -f "$_MANIFEST" ;;
  esac
fi

# Built-in finalize: applied macOS defaults don't take effect until the owning
# apps restart — a universal consequence of osx_default, so the engine does it
# (not the botufile). Only when defaults actually changed, on apply.
if [[ "$VERB" != "verify" && "$_OSX_APPLIED" == "1" && "$(os_kind)" == "darwin" && "${DRY_RUN:-0}" != "1" ]]; then
  _hdr "macOS finalize"
  killall Dock Finder SystemUIServer 2> /dev/null || true
  _ok "restarted Dock/Finder/SystemUIServer (defaults changed)"
fi

# ── Summary + exit code ───────────────────────────────────────────────────────
if [[ "$VERB" == "verify" ]]; then
  printf '\n'
  if [[ "$_FAIL" -gt 0 ]]; then
    _p_fail "verify: ${_FAIL} failure(s), ${_WARN} warning(s)"
    exit 1
  elif [[ "$_WARN" -gt 0 ]]; then
    _p_warn "verify: ${_WARN} warning(s)"
    exit 2
  fi
  _p_ok "verify: all checks passed"
  exit 0
fi
# apply / fix / uninstall: any failure makes the run nonzero (CI/bootstrap care).
printf '\n'
if [[ "$_FAIL" -gt 0 ]]; then
  _p_fail "$VERB: ${_FAIL} failure(s)"
  exit 1
fi
printf '\033[0;32m==> %s done\033[0m\n' "$VERB"
